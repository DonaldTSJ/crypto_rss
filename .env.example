# Copy to .env.local or export these in your shell.
# Never commit real webhook URLs or API keys.

# Feishu/Lark custom bot webhook.
FEISHU_WEBHOOK_URL=

# Optional DeepSeek OpenAI-compatible analyzer.
# The MVP works without this key and falls back to heuristic analysis.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: deepseek (default) or heuristic.
CYTOP_ANALYZER=deepseek

# Optional Obsidian output.
OBSIDIAN_VAULT_NAME=Evolution
OBSIDIAN_VAULT_PATH=
OBSIDIAN_OUTPUT_DIR=crypto
