# Copy to .env.local or export these in your shell.
# Never commit real webhook URLs or API keys.

# Feishu/Lark custom bot webhook.
FEISHU_WEBHOOK_URL=

# Optional DeepSeek OpenAI-compatible analyzer.
# The MVP works without this key and falls back to heuristic analysis.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_EFFORT=low
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_CONTEXT_CHARS=1800
DEEPSEEK_TOP_K=30
DEEPSEEK_WORKERS=4

# Optional: deepseek (default) or heuristic.
CYTOP_ANALYZER=deepseek

# Supabase shared storage and dashboard data source.
# Use your project API URL, for example https://PROJECT_REF.supabase.co.
# Prefer a backend-only secret key or service_role key. Never expose it in a frontend.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TABLE=crypto_intel_items

# Optional local dashboard server.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765

# Optional local Obsidian sync. The app writes only inside
# OBSIDIAN_VAULT_PATH/OBSIDIAN_FOLDER when --obsidian-sync is set.
OBSIDIAN_VAULT_PATH=D:\ALLINONE\ALLINONE\crypto
OBSIDIAN_FOLDER=RWA Intel
